# Copy to .env and fill in. Do NOT commit .env.
# Generate the App Password at https://myaccount.google.com/apppasswords
# (requires 2FA enabled on the Google Account).
GMAIL_USER=your.email@example.com
GMAIL_APP_PASSWORD=
# Default recipient for digest emails. Override per-call with --to.
DIGEST_RECIPIENT=your.email@example.com
